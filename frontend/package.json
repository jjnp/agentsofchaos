{
	"name": "frontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:all": "bash -lc 'trap \"kill 0\" EXIT; bun run dev & bun run storybook & wait'",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "playwright install && svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"staged:files": "git diff --cached --name-only --diff-filter=ACMR --relative",
		"staged:verify": "lint-staged --diff=\"--cached\" --verbose",
		"verify:quick": "bun run staged:verify && bun run check",
		"terminal:test-server": "node scripts/terminal-test-server.mjs",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build"
	},
	"lint-staged": {
		"*.{js,cjs,mjs,ts,cts,mts,svelte}": [
			"bun x eslint --max-warnings=0",
			"bun x vitest related --run --passWithNoTests"
		],
		"*.{css,html,json,md,svelte,js,cjs,mjs,ts,cts,mts,yml,yaml}": "bun x prettier --check"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^22",
		"@vitest/browser-playwright": "^4.1.3",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"lint-staged": "^16.4.0",
		"playwright": "^1.59.1",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.7",
		"vitest": "^4.1.3",
		"vitest-browser-svelte": "^2.1.0",
		"storybook": "^10.3.5",
		"@storybook/sveltekit": "^10.3.5",
		"@storybook/addon-svelte-csf": "^5.1.2",
		"@chromatic-com/storybook": "^5.1.2",
		"@storybook/addon-vitest": "^10.3.5",
		"@storybook/addon-a11y": "^10.3.5",
		"@storybook/addon-docs": "^10.3.5",
		"eslint-plugin-storybook": "^10.3.5",
		"@vitest/coverage-v8": "4.1.4"
	},
	"dependencies": {
		"@xterm/addon-fit": "^0.10.0",
		"@xterm/addon-web-links": "^0.11.0",
		"@xterm/xterm": "^5.5.0",
		"ws": "^8.20.0"
	}
}
